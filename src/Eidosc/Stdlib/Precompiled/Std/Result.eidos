Result :: module {
    import Option
    import Trait
    import Ordering.{Ordering}
    import Ordering
    import TraitInvoke
    import Functor
    import Applicative
    import Foldable
    import Monad
    import Traversable

    Result[T, E] :: type { Ok(T) , Err(E) }
    ResultWith[E, T] :: type = Result[T, E];

    @internal
    identity[T] :: T -> T
    {
        value => value
    }

    @internal
    compose[A, B, C, E1: effects, E2: effects] :: (B -> C need E1) -> (A -> B need E2) -> A -> C need E1, E2
    {
        (g, f, value) => g(f(value))
    }

    @internal
    apply_to[A, B, E: effects] :: A -> (A -> B need E) -> B need E
    {
        (value, f) => f(value)
    }

    @internal
    bind_then[A, B, C, E, E1: effects, E2: effects] :: (A -> ResultWith[E, B] need E1) -> (B -> ResultWith[E, C] need E2) -> A -> ResultWith[E, C] need E1, E2
    {
        (f, g, value) => f(value).bind(g)
    }

    @internal
    ok_wrap[T, E] :: T -> ResultWith[E, T]
    {
        value => Ok(value)
    }

    is_ok[T, E] :: Result[T, E] -> Bool
    {
        Ok(_) => true,
        Err(_) => false
    }

    is_err[T, E] :: Result[T, E] -> Bool
    {
        Ok(_) => false,
        Err(_) => true
    }

    contains[T: Trait.Eq, E] :: Result[T, E] -> T -> Bool
    {
        Ok(value) => expected => TraitInvoke.eq_value(value)(expected),
        Err(_) => _ => false
    }

    contains_err[T, E: Trait.Eq] :: Result[T, E] -> E -> Bool
    {
        Ok(_) => _ => false,
        Err(error) => expected => TraitInvoke.eq_value(error)(expected)
    }

    map[T, U, E, F: effects] :: Result[T, E] -> (T -> U need F) -> Result[U, E] need F
    {
        Ok(value) => f => Ok(f(value)),
        Err(error) => _ => Err(error)
    }

    map_err[T, E, F, G: effects] :: Result[T, E] -> (E -> F need G) -> Result[T, F] need G
    {
        Ok(value) => _ => Ok(value),
        Err(error) => f => Err(f(error))
    }

    and_then[T, U, E, F: effects] :: Result[T, E] -> (T -> Result[U, E] need F) -> Result[U, E] need F
    {
        Ok(value) => f => f(value),
        Err(error) => _ => Err(error)
    }

    map_or[T, U, E, F: effects] :: Result[T, E] -> U -> (T -> U need F) -> U need F
    {
        Ok(value) => _ => f => f(value),
        Err(_) => fallback => _ => fallback
    }

    map_or_else[T, U, E, F1: effects, F2: effects] :: Result[T, E] -> (E -> U need F1) -> (T -> U need F2) -> U need F1, F2
    {
        Ok(value) => _ => f => f(value),
        Err(error) => fallback => _ => fallback(error)
    }

    and_[T, U, E] :: Result[T, E] -> Result[U, E] -> Result[U, E]
    {
        Ok(_) => other => other,
        Err(error) => _ => Err(error)
    }

    or_[T, E] :: Result[T, E] -> Result[T, E] -> Result[T, E]
    {
        Ok(value) => _ => Ok(value),
        Err(_) => other => other
    }

    or_else[T, E, F, G: effects] :: Result[T, E] -> (E -> Result[T, F] need G) -> Result[T, F] need G
    {
        Ok(value) => _ => Ok(value),
        Err(error) => f => f(error)
    }

    unwrap_or[T, E] :: Result[T, E] -> T -> T
    {
        Ok(value) => _ => value,
        Err(_) => fallback => fallback
    }

    unwrap_or_else[T, E, F: effects] :: Result[T, E] -> (E -> T need F) -> T need F
    {
        Ok(value) => _ => value,
        Err(error) => fallback => fallback(error)
    }

    unwrap_err_or[T, E] :: Result[T, E] -> E -> E
    {
        Ok(_) => fallback => fallback,
        Err(error) => _ => error
    }

    flatten[T, E] :: Result[Result[T, E], E] -> Result[T, E]
    {
        Ok(inner) => inner,
        Err(error) => Err(error)
    }

    ok[T, E] :: Result[T, E] -> Option[T]
    {
        Ok(value) => Some(value),
        Err(_) => None()
    }

    err[T, E] :: Result[T, E] -> Option[E]
    {
        Ok(_) => None(),
        Err(error) => Some(error)
    }

    FoldableResultWithE[E] :: instance Foldable.Foldable[ResultWith[E]] {
        fold_left[A, B, E, F: effects] :: ResultWith[E, A] -> B -> (B -> A -> B need F) -> B need F
            {
                Ok(value) => acc => f => f(acc)(value),
                Err(_) => acc => _ => acc
            }
        fold_right[A, B, E, F: effects] :: ResultWith[E, A] -> B -> (A -> B -> B need F) -> B need F
            {
                Ok(value) => acc => f => f(value)(acc),
                Err(_) => acc => _ => acc
            }
    }

    TraversableResultWithE[E] :: instance Traversable.Traversable[ResultWith[E]] {
        traverse[A, B, G: kind2 : Applicative.Applicative[G], E, F: effects] :: ResultWith[E, A] -> (A -> G[B] need F) -> G[ResultWith[E, B]] need F
            {
                Ok(value) => f => Traversable.map_applicative(Result.ok_wrap)(f(value)),
                Err(error) => _ => Traversable.lift_pure(Err(error))
            }
    }

    sequence[A, G: kind2 : Applicative.Applicative[G], E] :: ResultWith[E, G[A]] -> G[ResultWith[E, A]]
    {
        result => Traversable.traverse(result)(Traversable.identity_applicative)
    }

    EqResultTE :: instance Trait.Eq {
        eq[T: Trait.Eq, E: Trait.Eq] :: Result[T, E] -> Result[T, E] -> Bool
            {
                (Ok(leftValue), Ok(rightValue)) => TraitInvoke.eq_value(leftValue)(rightValue),
                (Ok(value), Err(error)) => false,
                (Err(error), Ok(value)) => false,
                (Err(leftValue), Err(rightValue)) => TraitInvoke.eq_value(leftValue)(rightValue)
            }
    }

    OrdResultTE :: instance Trait.Ord {
        compare[T: Trait.Ord, E: Trait.Ord] :: Result[T, E] -> Result[T, E] -> Ordering
            {
                (Ok(leftValue), Ok(rightValue)) => TraitInvoke.compare_value(leftValue)(rightValue),
                (Ok(value), Err(error)) => Greater(),
                (Err(error), Ok(value)) => Less(),
                (Err(leftValue), Err(rightValue)) => TraitInvoke.compare_value(leftValue)(rightValue)
            }
    }

    ShowResultTE :: instance Trait.Show {
        show[T: Trait.Show, E: Trait.Show] :: Result[T, E] -> String
            {
                Ok(value) => "Ok(" ++ TraitInvoke.show_value(value) ++ ")",
                Err(error) => "Err(" ++ TraitInvoke.show_value(error) ++ ")"
            }
    }

    FunctorResultWithE[E] :: instance Functor.Functor[ResultWith[E]] {
        fmap[A, B, E, F: effects] :: ResultWith[E, A] -> (A -> B need F) -> ResultWith[E, B] need F
            {
                result => f => Result.map(result)(f)
            }
    }

    ApplicativeResultWithE[E] :: instance Applicative.Applicative[ResultWith[E]] {
        pure[A, E] :: A -> ResultWith[E, A]
            {
                value => Ok(value)
            }
        apply[A, B, E, F: effects] :: ResultWith[E, A -> B need F] -> ResultWith[E, A] -> ResultWith[E, B] need F
            {
                Ok(f) => Ok(value) => Ok(f(value)),
                Err(error) => _ => Err(error),
                _ => Err(error) => Err(error)
            }
    }

    MonadResultWithE[E] :: instance Monad.Monad[ResultWith[E]] {
        pure[A, E] :: A -> ResultWith[E, A]
            {
                value => Ok(value)
            }
        bind[A, B, E, F: effects] :: ResultWith[E, A] -> (A -> ResultWith[E, B] need F) -> ResultWith[E, B] need F
            {
                result => f => Result.and_then(result)(f)
            }


            // ── Additional functions ──────────────────────────────────────
    }

    map2[A, B, C, E, F: effects] :: Result[A, E] -> Result[B, E] -> (A -> B -> C need F) -> Result[C, E] need F
    {
        left => right => f => match (left, right)
        {
            (Ok(a), Ok(b)) => Ok(f(a)(b)),
            (Err(e), _) => Err(e),
            (_, Err(e)) => Err(e)
        }
    }

    map_both[T, U, E, F, G1: effects, G2: effects] :: Result[T, E] -> (T -> U need G1) -> (E -> F need G2) -> Result[U, F] need G1, G2
    {
        Ok(value) => f => _ => Ok(f(value)),
        Err(error) => _ => g => Err(g(error))
    }

    transpose[T, E] :: Result[Option[T], E] -> Option[Result[T, E]]
    {
        Ok(Some(value)) => Some(Ok(value)),
        Ok(None()) => None(),
        Err(error) => Some(Err(error))
    }

    transpose_option[T, E] :: Option[Result[T, E]] -> Result[Option[T], E]
    {
        Some(Ok(value)) => Ok(Some(value)),
        Some(Err(error)) => Err(error),
        None() => Ok(None())
    }
}
