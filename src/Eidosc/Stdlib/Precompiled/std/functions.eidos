Functions :: module {
    import Traits
    import TraitInvoke

    id[T] :: T -> T { x => x }
    const[A, B] :: A -> B -> A { (a, b) => a }
    second[A, B] :: A -> B -> B { _ => value => value }
    compose[A, B, C, E1: effects, E2: effects] :: (B -> C need E1) -> (A -> B need E2) -> A -> C need E1, E2 { (f, g, x) => f(g(x)) }
    compose_left[A, B, C, E1: effects, E2: effects] :: (A -> B need E1) -> (B -> C need E2) -> A -> C need E1, E2 { (f, g, x) => g(f(x)) }
    pipe[A, B, E: effects] :: A -> (A -> B need E) -> B need E { (x, f) => f(x) }
    apply[A, B, E: effects] :: (A -> B need E) -> A -> B need E { (f, x) => f(x) }
    flip[A, B, C, E: effects] :: (A -> B -> C need E) -> B -> A -> C need E { (f, b, a) => f(a)(b) }
    chain[A, B, C, E1: effects, E2: effects] :: (A -> B need E1) -> (B -> C need E2) -> A -> C need E1, E2 { (f, g, x) => g(f(x)) }
    repeat[A, E: effects] :: Int -> (A -> A need E) -> A -> A need E
    {
        count => f => value => {
            mut remaining := count;
            mut result := value;
            loop {
                if remaining <= 0 then { break }
                else {
                    result = f(result);
                    remaining = remaining - 1;
                    ()
                }
            }
            result
        }
    }
    on[A, B, C, E1: effects, E2: effects] :: (B -> B -> C need E1) -> (A -> B need E2) -> A -> A -> C need E1, E2
    {
        combine => project => left => right => combine(project(left))(project(right))
    }
    not_pred[A, E: effects] :: (A -> Bool need E) -> A -> Bool need E
    {
        predicate => value => !predicate(value)
    }
    and_pred[A: Traits.Clone, E1: effects, E2: effects] :: (A -> Bool need E1) -> (A -> Bool need E2) -> A -> Bool need E1, E2
    {
        left => right => value => {
            left_value := TraitInvoke.clone_value(ref value);
            right_value := TraitInvoke.clone_value(ref value);
            if left(left_value) then { right(right_value) } else { false }
        }
    }
    or_pred[A: Traits.Clone, E1: effects, E2: effects] :: (A -> Bool need E1) -> (A -> Bool need E2) -> A -> Bool need E1, E2
    {
        left => right => value => {
            left_value := TraitInvoke.clone_value(ref value);
            right_value := TraitInvoke.clone_value(ref value);
            if left(left_value) then { true } else { right(right_value) }
        }
    }
    juxt[A: Traits.Clone, B, C, E1: effects, E2: effects] :: (A -> B need E1) -> (A -> C need E2) -> A -> (B, C) need E1, E2
    {
        left => right => value => {
            left_value := TraitInvoke.clone_value(ref value);
            right_value := TraitInvoke.clone_value(ref value);
            (left(left_value), right(right_value))
        }
    }
    converge[A: Traits.Clone, B, C, D, E1: effects, E2: effects, E3: effects] :: (B -> C -> D need E1) -> (A -> B need E2) -> (A -> C need E3) -> A -> D need E1, E2, E3
    {
        combine => left => right => value => {
            left_value := TraitInvoke.clone_value(ref value);
            right_value := TraitInvoke.clone_value(ref value);
            combine(left(left_value))(right(right_value))
        }
    }
}
